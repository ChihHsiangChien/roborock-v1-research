# ===========================================
# Roborock V1 研究專案 - Git Ignore 規則
# ===========================================

# 敏感資料 (請勿上傳)
secrets.md
*_secrets.*
*_credentials.*
*.secret
*.token
*.key
*.pem
*.crt
*.private

# 環境變數檔案
.env
.env.local
.env.*.local

# 本地配置文件
.local_config.*
config_local.*
user_config.*

# ===========================================
# 機器人下載資料 (包含位置座標)
# ===========================================
map_dump.json
map_latest.json
*_map.json
map_*.json
*.map

# 傾印資料
dump_data/
blackbox/
robot_data/
robot_backups/
*_robot_*

# 日誌檔案
*.log
logs/
*.rr.bkup
*.rr.bkup.decrypted
rrlogs_backup.tar.gz

# 設備設定檔
device.conf
device.token
device.uid
wpa_supplicant.conf
wifi.conf
interfaces
valetudo_config.json
valetudo*.json

# 備份檔案
backup/
backups/
*.bak
*.backup
*.tar
*.gz
*.zip

# ===========================================
# 本地輸出 (可從機器人重新生成)
# ===========================================
outputs/

# ===========================================
# 系統檔案
# ===========================================
.DS_Store
.AppleDouble
.LSOverride
*~
*.swp
*.swo

# IDE
.vscode/
.idea/

# SSH
.ssh/config
